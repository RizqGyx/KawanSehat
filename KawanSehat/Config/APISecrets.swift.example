//
//  For more keys, just add to the array below!
//

import Foundation

// MARK: - API Secrets (Gitignored - Keep your keys safe!)
struct APISecrets {
    // Add your Gemini API keys here (can have multiple for fallback mechanism)
    // 📌 These keys will be automatically rotated if one fails (rate limit, invalid, etc)
    static let GEMINI_API_KEYS = [
        "YOUR_GEMINI_API_KEY_1_HERE",      // Primary key
        "YOUR_GEMINI_API_KEY_2_HERE",      // Fallback 1
        "YOUR_GEMINI_API_KEY_3_HERE",      // Fallback 2
        "YOUR_GEMINI_API_KEY_4_HERE",      // Fallback 3
        "YOUR_GEMINI_API_KEY_5_HERE",      // Fallback 4
        // Add more keys as needed
    ]
}

